# AC-2035 — environment template.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env

# ── GCP ──────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Neo4j ────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j

# ── Zitadel (identity) ───────────────────────────────
ZITADEL_DOMAIN=localhost
# Masterkey MUST be exactly 32 characters (consumed by docker-compose).
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
# Service-account PAT for the kill-switch Zitadel session-kill provider.
ZITADEL_SERVICE_ACCOUNT_TOKEN=your-zitadel-sa-token

# ── Postgres (backing store for Zitadel; local dev only) ─
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres

# ── Cloudflare ───────────────────────────────────────
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# ── Pub/Sub ──────────────────────────────────────────
PUBSUB_TRIGGER_TOPIC=honeytoken-triggers
PUBSUB_TELEMETRY_TOPIC=telemetry-raw

# ── Deployer ─────────────────────────────────────────
ROTATION_INTERVAL_HOURS=24

# ── API (Phase 7) ────────────────────────────────────
# Kill-switch firing mode for POST /api/alerts/trigger: "manual" stages the
# actions for analyst approval (safer default); "auto" fires immediately.
KILLSWITCH_MODE=manual
# Comma-separated allowed CORS origins for the dashboard; "*" allows all (dev).
CORS_ORIGINS=*

# ── Notifier (U0) — external alerting ────────────────
# Optional. Leave as placeholders to disable a channel. When a webhook fails
# (404/403/timeout), the notifier trips a per-channel circuit breaker and writes
# a local .alert the dashboard polls at GET /api/notifications.
SLACK_WEBHOOK_URL=your-slack-webhook-url
DISCORD_WEBHOOK_URL=your-discord-webhook-url
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key
