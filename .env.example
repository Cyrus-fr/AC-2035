# AC-2035 — environment template.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env

# ── GCP ──────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Neo4j ────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j

# ── Zitadel (identity) ───────────────────────────────
ZITADEL_DOMAIN=localhost
# Masterkey MUST be exactly 32 characters (consumed by docker-compose).
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters

# ── Postgres (backing store for Zitadel; local dev only) ─
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres

# ── Cloudflare ───────────────────────────────────────
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

# ── Pub/Sub ──────────────────────────────────────────
PUBSUB_TRIGGER_TOPIC=honeytoken-triggers
PUBSUB_TELEMETRY_TOPIC=telemetry-raw

# ── Deployer ─────────────────────────────────────────
ROTATION_INTERVAL_HOURS=24

# ── API (Phase 7) ────────────────────────────────────
# Kill-switch firing mode for POST /api/alerts/trigger: "manual" stages the
# actions for analyst approval (safer default); "auto" fires immediately.
KILLSWITCH_MODE=manual
# Comma-separated allowed CORS origins for the dashboard; "*" allows all (dev).
CORS_ORIGINS=*
